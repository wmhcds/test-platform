# ==========================================================
# AI 用例执行平台 - 环境变量配置
# 复制此文件为 .env 后按需修改
# ==========================================================

# ---------- 部署模式 ----------
# DEV=本地开发, DOCKER=Docker部署, CLOUDBASE=腾讯云CloudBase
DEPLOY_MODE=DEV

# ---------- 后端配置 ----------
SERVER_PORT=8000

# ---------- 前端配置 (Docker模式) ----------
WEB_PORT=80

# ---------- 数据库配置 ----------
# 数据库类型: sqlite (本地/COS挂载) | mysql (CloudBase云数据库)
DB_TYPE=sqlite

# SQLite 路径
DB_PATH=/app/data/test_platform.db

# MySQL 配置 (DB_TYPE=mysql 时生效)
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=your-password
# MYSQL_DATABASE=test_platform

# ---------- 通用 ----------
TZ=Asia/Shanghai
